<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<title>Interactive DOM Demo</title>

<style>

body{
font-family: Verdana, sans-serif;
padding: 25px;
background-color: #f4f6f8;
}

button{
margin: 6px;
padding: 7px 14px;
cursor: pointer;
border-radius: 4px;
border: none;
background-color: #4CAF50;
color: white;
}

#listContainer li{
margin: 6px 0;
color: #222;
}

</style>

</head>

<body>

<h1 id="titleText">
Hello User!
</h1>

<h2>
Live Clock:
</h2>

<p id="clock"></p>

<button onclick="updateHeading()">
Click to Change Title
</button>

<h2>
Enter Items
</h2>

<input type="text"
id="textInput"
placeholder="Type something...">

<button onclick="insertItem()">
Add
</button>

<ul id="listContainer"></ul>

<script>

function showTime()
{

const current = new Date();

document.getElementById("clock").textContent =
current.toLocaleTimeString();

}

setInterval(showTime,1000);

showTime();

function updateHeading()
{

const title =
document.getElementById("titleText");

title.textContent = "Title Updated!";

title.style.color = "green";

}

function insertItem()
{

const inputBox =
document.getElementById("textInput");

const text =
inputBox.value.trim();

if(text.length === 0)
{
alert("Input cannot be empty!");
return;
}

const newItem =
document.createElement("li");

newItem.textContent = text;

newItem.addEventListener("click",function()
{
this.remove();
});

document.getElementById("listContainer")
.appendChild(newItem);

inputBox.value = "";

}

</script>

</body>

</html>
