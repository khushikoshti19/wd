<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CSS Styling Example</title>

<link rel="stylesheet" href="styles.css">

<style>

body{
font-family: Arial, sans-serif;
margin: 20px;
background-color: #f4f4f4;
}

h1{
color: navy;
border-bottom: 2px solid navy;
padding-bottom: 10px;
}

table{
width: 80%;
margin: 20px auto;
border-collapse: collapse;
}

th,td{
padding: 12px;
text-align: left;
border-bottom: 1px solid #ddd;
}

tbody tr:nth-child(even){
background-color: #e6e6e6;
}

caption{
caption-side: top;
font-weight: bold;
margin-bottom: 10px;
}

</style>

</head>

<body>

<h1>Applying CSS Styles</h1>

<h2 style="color: crimson; text-align: center; background-color: #ffcccb; padding: 5px;">
Heading with Inline CSS
</h2>

<p>This paragraph is styled by the external CSS file.</p>

<table>

<caption>Styled Data Table</caption>

<thead>
<tr>
<th>First Name</th>
<th>Last Name</th>
<th>Role</th>
</tr>
</thead>

<tbody>

<tr>
<td>Rishi</td>
<td>Deore</td>
<td>Developer</td>
</tr>

<tr>
<td>Palak</td>
<td>Smith</td>
<td>Designer</td>
</tr>

<tr>
<td>Kartik</td>
<td>Jones</td>
<td style="font-weight: bold; color: green;">Manager</td>
</tr>

<tr>
<td>Anushka</td>
<td>Johnson</td>
<td>Tester</td>
</tr>

<tr>
<td>Bhumi</td>
<td>Marathe</td>
<td>Analyst</td>
</tr>

</tbody>

</table>

</body>
</html>
